# --- Obligatoire (frontend, build Vite / Netlify) ---
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Stripe Payment Links (optionnel : sinon URLs par défaut dans src/lib/stripePaymentLinks.js) ---
# Dans Stripe Dashboard > Payment Links : chaque lien doit correspondre au bon produit (mensuel récurrent, 1 mois ponctuel, annuel).
# L’application ajoute ?client_reference_id=<UUID utilisateur Supabase> pour le webhook.
# VITE_STRIPE_PAYMENT_LINK_RECURRING=https://buy.stripe.com/...
# VITE_STRIPE_PAYMENT_LINK_MONTHLY_ONETIME=https://buy.stripe.com/...
# VITE_STRIPE_PAYMENT_LINK_YEARLY=https://buy.stripe.com/...

# --- Stripe côté serveur (secrets Supabase Edge Functions, PAS dans Netlify pour le webhook) ---
# supabase secrets set STRIPE_SECRET_KEY=sk_...
# supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
# supabase secrets set STRIPE_PRICE_RECURRING_MONTHLY=price_xxx
# supabase secrets set STRIPE_PRICE_ONE_MONTH=price_xxx
# supabase secrets set STRIPE_PRICE_YEARLY_SUB=price_xxx
# supabase secrets set STRIPE_PRICE_YEARLY_ONETIME=price_xxx
# Déployer : supabase functions deploy stripe-webhook
# Stripe Dashboard > Webhooks : URL https://<project-ref>.supabase.co/functions/v1/stripe-webhook
# Événements : checkout.session.completed, customer.subscription.updated, customer.subscription.deleted, invoice.paid

# --- Supabase Storage ---
# Bucket "logos" : appliquer la migration supabase/migrations/20260418140000_storage_logos_bucket_policies.sql
# (lecture publique, écriture authentifiée dans le dossier {user_id}/)

# --- Edge Functions (secrets Supabase, pas Vite) ---
# Copier supabase/edge.env.example → supabase/edge.env puis :
#   npm run supabase:secrets
# Les STRIPE_PRICE_* doivent être des price_... (Stripe → Produits → Prix), pas des URLs buy.stripe.com.
